@model IEnumerable<CursoASPAjax.Personas>

@{
    ViewBag.Title = "Listado de Personas";
}

<h2 class="text-primary"><i class="glyphicon glyphicon-user"></i> Listado de Personas</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <p>
            @Html.ActionLink("Crear Nueva Persona", "Create", null, new { @class = "btn btn-success" })
        </p>
    </div>
    <div class="col-md-8 text-right">
        @using (Html.BeginForm("Index", "Personas", FormMethod.Get, new { @class = "form-inline justify-content-end" }))
        {
            <div class="input-group">
                <input type="text" name="term" id="personaSearch" 
                       class="form-control" placeholder="Buscar por nombre..." 
                       value="@Request.QueryString["term"]" autocomplete="off" 
                       data-url="@Url.Action("GetPersonasSuggestions", "Personas")" />
                <div class="input-group-append">
                    <button type="submit" class="btn btn-primary">
                        <i class="glyphicon glyphicon-search"></i> Buscar
                    </button>
                    @if (!string.IsNullOrEmpty(Request.QueryString["term"]))
                    {
                        <a href="@Url.Action("Index")" class="btn btn-default">Limpiar</a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<div class="card bg-light p-3 border-0 shadow-sm rounded mb-4">
    <div class="row align-items-center">
        <div class="col-md-4">
            @Html.ActionLink("Filtrar por Pais (SP)", "BuscarPersonaPais", null, new { @class = "btn btn-outline-info btn-block" })
        </div>
        <div class="col-md-8 border-left">
            <h4 class="text-warning mt-0">Filtro Dinámico de Edad</h4>
            <div class="row align-items-center">
                <div class="col-md-4">
                    <label class="text-muted small mb-0">Rango seleccionado:</label>
                    <input type="text" id="edades" readonly style="border:0; color:orange; font-weight:bold; background:transparent; width: 100%;" />
                </div>
                <div class="col-md-8">
                    <div id="slider-range"></div>
                </div>
            </div>

            @using (Ajax.BeginForm("cambioSlider", "Personas", new AjaxOptions()
            {
                HttpMethod = "POST",
                InsertionMode = InsertionMode.Replace,
                UpdateTargetId = "resultados"
            }, new { id = "formSlider", @class = "hidden" })) 
            {
                <input type="hidden" name="min" id="min" />
                <input type="hidden" name="max" id="max" />
            }
        </div>
    </div>
</div>

<hr />

<div id="resultados" class="mt-4">
    @Html.Partial("_TablaPersonas", Model)
</div>

@section scripts {
    @* jQuery UI CSS desde CDN *@
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    
    @* Scripts necesarios en orden *@
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-ajax-unobtrusive/3.2.6/jquery.unobtrusive-ajax.min.js"></script>
    
    @* Nuestro nuevo archivo externo de lógica *@
    <script src="~/Scripts/App/Personas/index-personas.js"></script>
}
